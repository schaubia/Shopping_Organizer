# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite — no setup needed)
DATABASE_URL=sqlite:///./nutritrack.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/nutritrack

# ── USDA FoodData Central ─────────────────────────────────────────────────────
# Free key: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=DEMO_KEY

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 1 week

# ── Stripe (fill in when ready to charge) ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
