{
  "compilerOptions": {
    "lib":     ["dom", "dom.iterable", "esnext"],
    "target":  "ES2017",
    "module":  "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict":  true,
    "jsx":     "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths":   { "@/*": ["./src/*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
